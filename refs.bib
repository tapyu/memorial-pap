  title = {Smoother-{{Based GPS Signal Tracking}} in a {{Software Receiver}}},
  booktitle = {Proceedings of the 14th {{International Technical Meeting}} of the {{Satellite Division}} of {{The Institute}} of {{Navigation}} ({{ION GPS}} 2001)},
