@article{ratnamAutomaticIonosphericScintillation2015,
  title = {Automatic Ionospheric Scintillation Detector for Global Navigation Satellite System Receivers},
  author = {Ratnam, Devanaboyina Venkata and Sivavaraprasad, Gampala and Lee, Jiyun},
  year = 2015,
  journal = {IET Radar, Sonar \& Navigation},
  volume = {9},
  number = {6},
  pages = {702--711},
  issn = {1751-8792},
  doi = {10.1049/iet-rsn.2014.0232},
  urldate = {2025-03-02},
  abstract = {Severe ionosphere scintillations have been known to affect the performance and measurement accuracy of Global Navigation Satellite System (GNSS) receivers. The scintillation in signal amplitude and phase reduces the number of available GNSS satellites by causing the loss of lock in GNSS receivers. Hence, the investigation of ionospheric scintillations is imperative for monitoring the activities of the atmosphere, ionosphere and space weather. Scintillations can be modelled as a function of scintillation indices like amplitude scintillation index (S4), phase scintillation index ({$\sigma$}\O ), C/N and elevation angle with respect to the time. In this study, the GNSS Ionospheric Scintillation and TEC monitor receiver located at the K L University, Vaddeswaram, India, sited in low latitudes, provided the data for the real-time analysis of ionospheric scintillations. This paper describes an ionospheric scintillation model (RTISM), which determines the automatic threshold for different scintillation signals using the Neyman Pearson detector. The results of the RTISM model include estimation, detection and mitigation of ionospheric scintillations using wavelet analysis, Hilbert--Huang transform and binary hypothesis test. The RTISM model has been tested for major scintillation events observed during the geomagnetic storms that occurred in the maximum solar activity periods of the 24th solar cycle (2013--2014).},
  copyright = {\copyright{} 2020 The Institution of Engineering and Technology},
  langid = {english},
  keywords = {amplitude scintillation index,binary hypothesis test,eastward current flow,elevation angle,equatorial electrojet,equatorial ionisation anomaly,equatorial regions,geomagnetic storms,global navigation satellite system receivers,GNSS ionospheric scintillation,GNSS receivers,GNSS satellites,Hilbert transforms,Hilbert-Huang transform,Indian Standard Time,ionosphere scintillation detector,ionospheric electromagnetic wave propagation,ionospheric irregularity drifts,ionospheric scintillation model,low latitude regions,maximum solar activity periods,Neyman Pearson detector,phase scintillation index,radio receivers,real-time analysis,RTISM,satellite navigation,scintillation indices,scintillation signals,signal amplitude,total electron content (atmosphere),total electron content monitor receiver,wavelet analysis,wavelet denoising,wavelet transforms}
}

