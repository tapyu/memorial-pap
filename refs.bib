  volume = {3},
  number = {1},
  issn = {0103-1759},
  doi = {10.20906/CBA2022/3299},
  urldate = {2026-05-20},
  abstract = {Artificial Intelligence techniques, mainly machine and deep learning ones, are becom- ing the most common approach for data prediction. In this context, using these techniques instead of approaches based on classical statistics has shown interesting and important contri- butions to weather prediction. The present paper discusses the prediction of rainfall and clouds direction based on a sequence of 10 and 14 frames of radar images with a loss inferior to 0.06. Two different Convolutional Long-Short Term Memory Networks configurations were tested and this work presents the estimated frames resulting from these algorithms and presents comparisons between them, real data, and with the performance of other works. The results show that these algorithms can be suitable for short-term weather forecasting.},
  copyright = {Copyright (c)},
  langid = {english},
  keywords = {Artificial intelligence,ConvLSTM,image processing,machine learning,weather forecasting}
}

