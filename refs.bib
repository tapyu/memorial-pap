@article{danielebarrocamarraalvesCorrelationIonosphericScintillation2020,
  title = {Correlation between Ionospheric Scintillation Effects and {{GNSS}} Positioning over {{Brazil}} during the Last Solar Maximum (2012--2014)},
  author = {{Daniele Barroca Marra Alves} and {Eniuce Menezes De Souza} and {Tayn\'a Aparecida Ferreira Gouveia}},
  year = 2020,
  month = jan,
  journal = {Journal of Atmospheric and Solar-Terrestrial Physics},
  volume = {197},
  pages = {105019},
  issn = {1364-6826},
  doi = {10.1016/j.jastp.2019.03.013},
  urldate = {2025-01-23},
  abstract = {GNSS (Global Navigation Satellite Systems) can provide high accuracy positioning at low cost. But, depending on the sources of error, e.g. the atmospheric effects, this accuracy can be degraded. The ionosphere is one of the most important error sources in GNSS positioning. Among several effects caused by the ionosphere, irregularities such as ionospheric scintillations are very relevant. They can cause cycle slips, degrade the positioning accuracy and, when severe enough, can even lead to a complete loss of signal lock. Brazil, in particular, is located in one of the regions most affected by ionospheric scintillations and these effects were intensified during the last solar maximum. The main goal of this paper is to evaluate the impact of scintillation effects on the degradation of positioning during the last solar maximum. Data from 2012 to 2014 of three reference stations located in different regions of Brazil was used. Statistically significant correlations were identified from Spearman's correlation coefficient. Using Odds Ratio, an effect-size statistic, it was possible to see that the chance of large discrepancies in 3D positioning coordinates could be three times greater under strong scintillation effects (S4 {$\geq$} 1) than under moderate ones (0.5},
  keywords = {GNSS positioning,Ionosphere,Odds ratio,Scintillation,Spearman correlation,Time series}
}

@article{dardariIndoorTrackingTheory2015,
  title = {Indoor {{Tracking}}: {{Theory}}, {{Methods}}, and {{Technologies}}},
  shorttitle = {Indoor {{Tracking}}},
  author = {Dardari, Davide and Closas, Pau and Djuri{\'c}, Petar M.},
  year = 2015,
  month = apr,
  journal = {IEEE Transactions on Vehicular Technology},
  volume = {64},
  number = {4},
  pages = {1263--1278},
  issn = {1939-9359},
  doi = {10.1109/TVT.2015.2403868},
  urldate = {2025-01-17},
  abstract = {In the last decade, the research on and the technology for outdoor tracking have seen an explosion of advances. It is expected that in the near future, we will witness similar trends for indoor scenarios where people spend more than 70\% of their lives. The rationale for this is that there is a need for reliable and high-definition real-time tracking systems that have the ability to operate in indoor environments, thus complementing those based on satellite technologies, such as the Global Positioning System (GPS). The indoor environments are very challenging, and as a result, a large variety of technologies have been proposed for coping with them, but no legacy solution has emerged. This paper presents a survey on indoor wireless tracking of mobile nodes from a signal processing perspective. It can be argued that the indoor tracking problem is more challenging than the problem on indoor localization. The reason is simple: From a set of measurements, one has to estimate not one location but a series of correlated locations of a mobile node. The paper illustrates the theory, the main tools, and the most promising technologies for indoor tracking. New directions of research are also discussed.},
  keywords = {Accuracy,Bayesian filtering,data fusion,Estimation,indoor tracking,Indoor tracking,Magnetometers,Mobile nodes,Position measurement,simultaneous localization,simultaneous localization and mapping (SLAM),technologies for tracking,Wireless communication}
}

