@inproceedings{riceBitErrorRate1981,
  title = {The {{Bit Error Rate Performance Of Load Management Receivers Using AFSK Signaling}}},
  booktitle = {Conference {{Proceedings Southeastcon}} '81.},
  author = {Rice, R.W.},
  year = 1981,
  pages = {170--173},
  publisher = {IEEE},
  address = {Huntsville, AL},
  doi = {10.1109/SECON.1981.673422},
  urldate = {2025-02-15},
  abstract = {In the course of designing a radio-based load management system, it is necessary to define the coverage area of a given transmitter. One part of this exercise would of necessity involve predicting area coverage using s tandard propagation models; however, before this can be done one must establish a minimum field intensity for reliable switch operation. This p aper presents an analysis of the bit error r ate performance of a typical load management receiver configuration using non-coherent detection of audio frequency shift keying (AFSK) on a frequency-modula ted carrier. The solution presented relates the r eceiver's bit error rate to the ambient electric f ield intensity, the ambient noise environment (urban or suburban), the baud interval of the transmission, and the bandwidth of the mark/space channel filters.}
}

