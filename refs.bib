@article{aulinContinuousPhaseModulation1981,
  title = {Continuous {{Phase Modulation}} - {{Part I}}: {{Full Response Signaling}}},
  shorttitle = {Continuous {{Phase Modulation}} - {{Part I}}},
  author = {Aulin, T. and Sundberg, C.},
  year = 1981,
  month = mar,
